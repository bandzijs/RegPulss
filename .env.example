# Copy this file to .env.local and fill in your Supabase credentials
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Site URL (used for confirmation links in emails)
NEXT_PUBLIC_SITE_URL=https://reg-pulss.vercel.app

# Zoho Mail SMTP Configuration (server-only — do NOT prefix with NEXT_PUBLIC_)
# Use smtp.zoho.com (US), smtp.zoho.eu (EU), or smtppro.zoho.in (India)
# If 2FA is enabled, generate an App Password in Zoho: Settings > Security > App Passwords
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=your-email@regpulss.lv
SMTP_PASS=your-zoho-app-password
SMTP_FROM=RegPulss <your-email@regpulss.lv>
